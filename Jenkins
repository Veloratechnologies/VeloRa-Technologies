pipeline {
    agent any

    triggers {
        githubPush()
    }

    environment {
        APP_DIR = "/var/www/html/VeloRa-Technologies"
    }

    stages {

        stage('Pull Latest Code') {
            steps {
                sh '''
                git config --global --add safe.directory $APP_DIR
                cd $APP_DIR
                git reset --hard HEAD
                git pull origin main
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                cd $APP_DIR

                # ONLY use npm ci in CI
                npm ci --no-audit --no-fund
                '''
            }
        }

        stage('Build') {
            steps {
                sh '''
                cd $APP_DIR
                npm run build
                '''
            }
        }

        stage('Restart Application') {
            steps {
                sh '''
                pm2 restart all
                pm2 save
                '''
            }
        }
    }

    post {
        success {
            echo 'Deployment Successful'
        }

        failure {
            echo 'Deployment Failed'
        }
    }
}