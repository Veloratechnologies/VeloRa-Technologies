pipeline {
    agent any

    triggers {
        githubPush()
    }

    stages {

        stage('Pull Latest Code') {
            steps {
                sh '''
                git config --global --add safe.directory /var/www/html/VeloRa-Technologies
                cd /var/www/html/VeloRa-Technologies
                git reset --hard HEAD
                git pull origin main
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                cd /var/www/html/VeloRa-Technologies
                rm -rf node_modules package-lock.json
                npm ci --no-audit --no-fund
                npm install axios
                '''
            }
        }

        stage('Build') {
            steps {
                sh '''
                cd /var/www/html/VeloRa-Technologies
                npm run build
                '''
            }
        }

        stage('Restart Application') {
            steps {
                sh '''
                pm2 restart all
                pm2 save
                '''
            }
        }
    }

    post {
        success {
            echo 'Deployment Successful'
        }

        failure {
            echo 'Deployment Failed'
        }
    }
}